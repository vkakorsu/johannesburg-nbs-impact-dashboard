---
import { t } from "../i18n";
---

<footer class="mt-24 border-t border-rule bg-charcoal text-paper">
  <div class="mx-auto grid max-w-page gap-8 px-5 py-12 md:grid-cols-[1.4fr_1fr_1fr]">
    <div>
      <p class="eyebrow text-clay-soft" data-i18n="hero.eyebrow">SUNCASA Johannesburg</p>
      <p class="headline mt-2 text-xl" data-i18n="site.title">Johannesburg Nature-based Solutions Impact Dashboard</p>
      <p class="mt-3 max-w-prose text-sm text-paper/70" data-i18n="footer.project">
        SUNCASA, Scaling Urban Nature based Solutions for Climate Adaptation in Sub Saharan Africa
      </p>
    </div>

    <div class="text-sm text-paper/80">
      <p class="eyebrow text-paper/50">Ownership</p>
      <p class="mt-2" data-i18n="footer.owner">Hosted and owned by the City of Johannesburg Environment and Infrastructure Services Department</p>
      <p class="mt-2 text-paper/60" data-i18n="footer.rights">
        Full ownership of code, configuration, and data rests with the City of Johannesburg.
      </p>
    </div>

    <div class="text-sm text-paper/80">
      <p class="eyebrow text-paper/50">Partners</p>
      <p class="mt-2" data-i18n="footer.partners">
        Led by IISD and the World Resources Institute, funded by Global Affairs Canada, with the City of Johannesburg, JCPZ, JICP, Water for the Future, GenderCC, Zutari, and the Alexandra Water Warriors
      </p>
      <p class="mt-3 inline-flex rounded-full border border-paper/25 px-3 py-1 text-xs text-paper/70" data-i18n="badge.illustrative">
        Illustrative sample data
      </p>
    </div>
  </div>
</footer>
