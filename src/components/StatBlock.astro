---
import { t } from "../i18n";
import type { Indicator } from "../data";
import { getPillar } from "../data";
import TrendPill from "./TrendPill.astro";

interface Props {
  indicator: Indicator;
}
const { indicator } = Astro.props;
const pillar = getPillar(indicator.pillar);
const value = indicator.latestValue;
const display = value === null ? "n/a" : Intl.NumberFormat("en").format(value);
---

<a
  href={`/${pillar.slug}`}
  class="group flex flex-col justify-between rounded-md border border-rule bg-paper p-5 transition-colors hover:border-emerald/40"
>
  <div class="flex flex-col gap-2">
    <div class="flex justify-end">
      <TrendPill trend={indicator.trend} goodDirection={indicator.id === "flood_extent" || indicator.id === "streamflow" ? "down" : "up"} />
    </div>
    <span class="eyebrow text-charcoal/50" style={`color:${pillar.accent}`} data-i18n={pillar.labelKey}>
      {t(pillar.labelKey)}
    </span>
  </div>
  <div class="mt-4">
    <span class="headline tnum block text-4xl text-charcoal">{display}</span>
    <span class="mt-1 block text-sm text-charcoal/60">{indicator.unit}</span>
  </div>
  <p class="mt-3 text-sm text-charcoal/80" data-i18n={`ind.${indicator.id}.name`}>{indicator.name.en}</p>
</a>
