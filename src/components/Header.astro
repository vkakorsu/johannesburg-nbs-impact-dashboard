---
import LangToggle from "./LangToggle.tsx";
import MobileMenu from "./MobileMenu.tsx";
import { t } from "../i18n";
import { pillars } from "../data";

interface Props {
  active?: string;
}
const { active } = Astro.props;

const nav = [
  { href: "/", key: "nav.home", id: "home" },
  ...pillars.map((p) => ({ href: `/${p.slug}`, key: p.labelKey, id: p.id })),
  { href: "/about-data", key: "nav.data", id: "data" },
  { href: "/methodology", key: "nav.methodology", id: "methodology" },
];

const mobileItems = nav.map((item) => ({
  href: item.href,
  label: t(item.key),
  i18nKey: item.key,
  active: active === item.id,
}));
---

<header class="border-b border-rule bg-paper/95 backdrop-blur supports-[backdrop-filter]:bg-paper/80 sticky top-0 z-40">
  <div class="mx-auto max-w-page px-4 py-2.5 sm:px-5 sm:py-3">
    <!-- Top row: logo + title on the left, controls on the right. Same on mobile and desktop. -->
    <div class="flex items-center justify-between gap-3">
      <a href="/" class="group flex items-center gap-2.5 min-w-0" aria-label={t("site.title")}>
        <span class="grid h-8 w-8 shrink-0 place-items-center rounded-sm bg-emerald text-paper sm:h-9 sm:w-9" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" class="sm:w-5 sm:h-5">
            <path d="M4 18c3 0 3-2 6-2s3 2 6 2 3-2 4-2" />
            <path d="M4 13c3 0 3-2 6-2s3 2 6 2 3-2 4-2" />
            <path d="M12 3c2.5 2 3 4 3 6H9c0-2 .5-4 3-6Z" />
          </svg>
        </span>
        <span class="min-w-0 leading-tight">
          <span class="block eyebrow text-emerald !text-[0.65rem] sm:!text-[0.78rem]" data-i18n="hero.eyebrow">SUNCASA Johannesburg</span>
          <!-- Short title on mobile, full title on md+ -->
          <span class="headline block text-sm text-charcoal md:hidden" data-i18n="site.title.short">NbS Impact Dashboard</span>
          <span class="headline hidden text-base text-charcoal md:block" data-i18n="site.title">Johannesburg Nature-based Solutions Impact Dashboard</span>
        </span>
      </a>

      <div class="flex items-center gap-2 sm:gap-3 shrink-0">
        <!-- Language toggle: hidden on small mobile (available in mobile menu), visible on sm+ -->
        <div class="hidden sm:block">
          <LangToggle client:load />
        </div>
        <MobileMenu client:load items={mobileItems} />
      </div>
    </div>

    <!-- Desktop nav sits below the title row. Hidden on mobile and tablet. -->
    <nav aria-label="Primary" class="hidden lg:block mt-2">
      <ul class="flex items-center gap-7 text-sm">
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              aria-current={active === item.id ? "page" : undefined}
              class:list={[
                "hover:text-emerald transition-colors",
                active === item.id ? "text-emerald font-semibold" : "text-charcoal/75",
              ]}
              data-i18n={item.key}
            >
              {t(item.key)}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
