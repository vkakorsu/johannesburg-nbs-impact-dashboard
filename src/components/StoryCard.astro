---
import { t } from "../i18n";

interface Props {
  title: string;
  excerpt: string;
  place: string;
  accent?: string;
  titleKey?: string;
  excerptKey?: string;
}
const { title, excerpt, place, accent = "#3B7EA1", titleKey, excerptKey } = Astro.props;
---

<article class="flex flex-col overflow-hidden rounded-md border border-rule bg-paper">
  <div class="relative flex h-40 w-full items-center justify-center" style={`background:linear-gradient(135deg, ${accent}, #0B3D2E)`} role="img" aria-label={`${t("story.label")}: ${place}`}>
    <span class="absolute left-4 top-4 rounded-full bg-paper/90 px-2.5 py-0.5 text-xs font-semibold text-charcoal" data-i18n="story.label">
      {t("story.label")}
    </span>
    <span class="inline-flex items-center gap-1.5 text-xs font-medium text-paper/80" data-i18n="story.photo">
      {t("story.photo")}
    </span>
    <span class="absolute bottom-3 left-4 text-xs font-medium uppercase tracking-wider text-paper/85">{place}</span>
  </div>
  <div class="flex flex-1 flex-col p-5">
    <h3 class="headline text-lg text-charcoal" data-i18n={titleKey}>{title}</h3>
    <p class="mt-2 flex-1 text-sm text-charcoal/80" data-i18n={excerptKey}>{excerpt}</p>
    <p class="mt-3 text-xs text-charcoal/50" data-i18n="story.disclaimer">Narrative and translation to be supplied by IISD and the City of Johannesburg.</p>
  </div>
</article>
