---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found">
  <section class="mx-auto max-w-page px-5 py-28 text-center">
    <p class="eyebrow text-emerald" data-i18n="hero.eyebrow">SUNCASA Johannesburg</p>
    <h1 class="headline mt-3 text-5xl text-charcoal" data-i18n="404.title">Page not found</h1>
    <p class="mx-auto mt-4 max-w-prose text-charcoal/75" data-i18n="404.body">
      The page you are looking for is not part of this MVP dashboard.
    </p>
    <a href="/" class="mt-8 inline-flex rounded-sm bg-emerald px-5 py-3 text-sm font-semibold text-paper hover:bg-emerald-mid" data-i18n="common.backHome">
      Back to overview
    </a>
  </section>
</BaseLayout>
