---
import "../styles/tokens.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getDictionaries, t } from "../i18n";
import { buildClientDictionaries } from "../data";

interface Props {
  title?: string;
  description?: string;
  active?: string;
}

const { title, description, active } = Astro.props;
const dictionaries = buildClientDictionaries(getDictionaries() as Record<"en" | "zu", Record<string, string>>);
const pageTitle = title ? `${title} | ${t("site.title")}` : t("site.title");
const pageDescription = description ?? t("site.tagline");
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <meta name="color-scheme" content="light" />
    <title>{pageTitle}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta name="robots" content="noindex, nofollow" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <!-- Dictionaries are embedded once so the language toggle is instant and works offline. -->
    <script type="application/json" id="suncasa-i18n" set:html={JSON.stringify(dictionaries)} />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header active={active} />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      import { initI18n } from "../scripts/i18n-client";
      const el = document.getElementById("suncasa-i18n");
      if (el && el.textContent) {
        window.__SUNCASA_I18N__ = JSON.parse(el.textContent);
      }
      initI18n();
    </script>
  </body>
</html>
